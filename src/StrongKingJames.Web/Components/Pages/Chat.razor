@page "/chat"
@rendermode InteractiveServer
@inject IRagService Rag
@inject IJSRuntime JS
@inject StrongKingJames.Web.Ollama.OllamaHealth Health
@inject StrongKingJames.Core.Ollama.OllamaOptions OllamaOpts

<PageTitle>Chat - StrongKingJames</PageTitle>

<h1>Ask the Bible</h1>

<OllamaStatusBanner />

<div class="chat-toolbar">
    <label for="model-select">Model:</label>
    <select id="model-select" @bind="_selectedModel" disabled="@(_busy || _models.Count == 0)">
        @if (_models.Count == 0)
        {
            <option value="">(loading models…)</option>
        }
        @foreach (var m in _models)
        {
            <option value="@m">@m</option>
        }
    </select>
    <button type="button" class="chat-clear" @onclick="ClearChat" disabled="@(_busy || _messages.Count == 0)">New chat</button>
</div>

<div class="chat-card">
    <div class="chat-history" id="chat-history">
        @if (_messages.Count == 0 && !_isStreaming)
        {
            <div class="chat-empty">
                <div class="chat-empty-icon">✝</div>
                <h2>Ask the Bible anything</h2>
                <p>Every answer is grounded in Scripture and includes verse citations.</p>
                <div class="chat-suggestions">
                    @foreach (var q in _suggestions)
                    {
                        <button type="button" class="chat-suggestion" @onclick="() => AskAsync(q)">@q</button>
                    }
                </div>
            </div>
        }

        @foreach (var msg in _messages)
        {
            <div class="chat-message @(msg.IsUser ? "user" : "assistant")">
                <div class="chat-avatar" aria-hidden="true">@(msg.IsUser ? "👤" : "📖")</div>
                <div class="chat-content">
                    <div class="chat-meta">
                        <span class="chat-name">@(msg.IsUser ? "You" : "StrongKingJames")</span>
                    </div>
                    <div class="chat-bubble @(msg.IsUser ? "" : "markdown")">
                        @if (string.IsNullOrEmpty(msg.Text) && !msg.IsUser)
                        {
                            <span class="chat-thinking">Thinking</span>
                        }
                        else if (msg.IsUser)
                        {
                            @msg.Text
                        }
                        else
                        {
                            @((MarkupString)StrongKingJames.Web.Rendering.MarkdownRenderer.ToHtml(msg.Text))
                        }
                    </div>
                    @if (!msg.IsUser && msg.Citations.Count > 0)
                    {
                        <div class="chat-citations">
                            @foreach (var c in msg.Citations)
                            {
                                <a class="chat-citation" href="@CitationLink(c)">@c</a>
                            }
                        </div>
                    }
                </div>
            </div>
        }

        @if (_isStreaming && _messages.LastOrDefault() is { IsUser: false } last && !string.IsNullOrEmpty(last.Text))
        {
            <div class="chat-message assistant">
                <div class="chat-avatar" aria-hidden="true">📖</div>
                <div class="chat-content">
                    <div class="chat-meta">
                        <span class="chat-name">StrongKingJames</span>
                    </div>
                    <div class="chat-bubble typing">
                        <span class="typing-dot"></span>
                        <span class="typing-dot"></span>
                        <span class="typing-dot"></span>
                    </div>
                </div>
            </div>
        }
    </div>

    <div class="chat-input-row">
        <textarea @bind="_question" @bind:event="oninput" rows="2" placeholder="Ask a question..." disabled="@_busy"></textarea>
        <button type="button" class="btn-primary" @onclick="() => AskAsync()" disabled="@(_busy || string.IsNullOrWhiteSpace(_question))">
            Send
        </button>
    </div>
</div>

@code {
    // Approximate character budget for prior turns sent as context. Older turns beyond this
    // are dropped from what we send (but still shown in the transcript).
    private const int HistoryContextBudgetChars = 8000;

    private string _question = "";
    private bool _busy;
    private bool _isStreaming;
    private List<ChatMessage> _messages = [];
    private List<string> _models = [];
    private string _selectedModel = "";

    private readonly string[] _suggestions =
    [
        "What does the Bible say about love?",
        "Explain John 3:16",
        "How can I find peace?",
        "What is faith?"
    ];

    protected override async Task OnInitializedAsync()
    {
        _models = (await Health.ListModelsAsync()).ToList();
        if (_models.Count > 0)
        {
            // Prefer the configured chat model (e.g. llama3.1:8b) over the alphabetical first.
            _selectedModel = _models.FirstOrDefault(m =>
                m.Equals(OllamaOpts.ChatModel, StringComparison.OrdinalIgnoreCase)
                || m.StartsWith(OllamaOpts.ChatModel, StringComparison.OrdinalIgnoreCase))
                ?? _models[0];
        }
    }

    private async Task AskAsync(string? suggestedQuestion = null)
    {
        var question = (suggestedQuestion ?? _question).Trim();
        if (_busy || string.IsNullOrWhiteSpace(question)) return;

        // Prior completed turns (before this question), converted and trimmed to the context budget.
        var priorTurns = _messages
            .Where(m => !string.IsNullOrEmpty(m.Text))
            .Select(m => new StrongKingJames.Core.Models.ChatMessage(m.IsUser ? "user" : "assistant", m.Text))
            .ToList();
        var priorContext = TrimToBudget(priorTurns, HistoryContextBudgetChars);

        _messages.Add(new ChatMessage { Text = question, IsUser = true });
        _question = "";
        _busy = true;
        _isStreaming = true;
        await ScrollToBottomAsync();

        var answer = new ChatMessage { Text = "", IsUser = false };
        _messages.Add(answer);

        var model = string.IsNullOrWhiteSpace(_selectedModel) ? null : _selectedModel;
        try
        {
            await foreach (var chunk in Rag.AnswerAsync(question, model, priorContext))
            {
                answer.Text += chunk;
                await InvokeAsync(StateHasChanged);
                await ScrollToBottomAsync();
            }
            answer.Citations = CitationExtractor.Extract(answer.Text).ToList();
        }
        catch (Exception ex)
        {
            answer.Text = $"Error: {ex.Message}. Is Ollama running with the model pulled?";
        }
        finally
        {
            _isStreaming = false;
            _busy = false;
            await InvokeAsync(StateHasChanged);
            await ScrollToBottomAsync();
        }
    }

    private void ClearChat()
    {
        _messages.Clear();
    }

    // Keep the most recent turns whose cumulative length fits the budget (drop oldest).
    private static IReadOnlyList<StrongKingJames.Core.Models.ChatMessage> TrimToBudget(
        List<StrongKingJames.Core.Models.ChatMessage> turns, int maxChars)
    {
        var kept = new List<StrongKingJames.Core.Models.ChatMessage>();
        var total = 0;
        for (var i = turns.Count - 1; i >= 0; i--)
        {
            total += turns[i].Content.Length;
            if (total > maxChars && kept.Count > 0) break;
            kept.Insert(0, turns[i]);
        }
        return kept;
    }

    private async Task ScrollToBottomAsync()
    {
        try
        {
            await JS.InvokeVoidAsync("scrollToBottom", "chat-history");
        }
        catch (JSDisconnectedException)
        {
            // Page may be disconnecting; ignore.
        }
    }

    // Turn "John 3:16" into "/browse/John/3" (best-effort; book name may differ from abbrev).
    private static string CitationLink(string citation)
    {
        var lastSpace = citation.LastIndexOf(' ');
        if (lastSpace < 0) return "/search?q=" + Uri.EscapeDataString(citation);
        var book = citation[..lastSpace].Trim();
        var chapterVerse = citation[(lastSpace + 1)..];
        var chapter = chapterVerse.Split(':')[0];
        return $"/browse/{Uri.EscapeDataString(book)}/{chapter}";
    }

    private sealed class ChatMessage
    {
        public string Text { get; set; } = "";
        public bool IsUser { get; set; }
        public List<string> Citations { get; set; } = [];
    }
}
