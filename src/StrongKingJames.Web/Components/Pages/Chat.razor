@page "/chat"
@rendermode InteractiveServer
@inject IRagService Rag

<PageTitle>Chat - StrongKingJames</PageTitle>

<h1>Ask the Bible</h1>

<OllamaStatusBanner />

<div class="chat-card">
    <div class="chat-history" id="chat-history">
        @if (_messages.Count == 0)
        {
            <div class="muted" style="text-align: center; padding: 2rem 0;">
                Ask a question and the answer will be grounded in Scripture with verse citations.
            </div>
        }
        else
        {
            @foreach (var msg in _messages)
            {
                <div class="chat-message @(msg.IsUser ? "user" : "assistant")">
                    <span class="chat-sender">@(msg.IsUser ? "You" : "StrongKingJames")</span>
                    <div class="chat-bubble">@msg.Text</div>
                    @if (!msg.IsUser && msg.Citations.Count > 0)
                    {
                        <div class="citations">
                            <strong>Scripture citations</strong>
                            <ul>
                                @foreach (var c in msg.Citations)
                                {
                                    <li><a href="@CitationLink(c)">@c</a></li>
                                }
                            </ul>
                        </div>
                    }
                </div>
            }
        }
    </div>

    <div class="chat-input-row">
        <textarea @bind="_question" @bind:event="oninput" rows="3" placeholder="Ask a question..." disabled="@_busy"></textarea>
        <button type="button" class="btn-primary" @onclick="AskAsync" disabled="@(_busy || string.IsNullOrWhiteSpace(_question))">Ask</button>
    </div>
</div>

@code {
    private string _question = "";
    private bool _busy;
    private List<ChatMessage> _messages = [];

    private async Task AskAsync()
    {
        if (string.IsNullOrWhiteSpace(_question)) return;

        var question = _question.Trim();
        _messages.Add(new ChatMessage { Text = question, IsUser = true });
        _question = "";
        _busy = true;

        var answer = new ChatMessage { Text = "", IsUser = false };
        _messages.Add(answer);

        try
        {
            await foreach (var chunk in Rag.AnswerAsync(question))
            {
                answer.Text += chunk;
                await InvokeAsync(StateHasChanged);
            }
            answer.Citations = CitationExtractor.Extract(answer.Text).ToList();
        }
        catch (Exception ex)
        {
            answer.Text = $"Error: {ex.Message}. Is Ollama running with the models pulled?";
        }
        finally
        {
            _busy = false;
        }
    }

    // Turn "John 3:16" into "/browse/John/3" (best-effort; book name may differ from abbrev).
    private static string CitationLink(string citation)
    {
        var lastSpace = citation.LastIndexOf(' ');
        if (lastSpace < 0) return "/search?q=" + Uri.EscapeDataString(citation);
        var book = citation[..lastSpace].Trim();
        var chapterVerse = citation[(lastSpace + 1)..];
        var chapter = chapterVerse.Split(':')[0];
        return $"/browse/{Uri.EscapeDataString(book)}/{chapter}";
    }

    private sealed class ChatMessage
    {
        public string Text { get; set; } = "";
        public bool IsUser { get; set; }
        public List<string> Citations { get; set; } = [];
    }
}
