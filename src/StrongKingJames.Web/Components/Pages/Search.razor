@page "/search"
@rendermode InteractiveServer
@inject IBibleRepository Repo
@inject ISearchService SearchService
@inject IEmbeddingService Embedder
@inject NoteService NoteSvc
@inject NavigationManager Nav

<PageTitle>Search - StrongKingJames</PageTitle>

<h1>Search Scripture</h1>

@if (_showOllamaBanner)
{
    <OllamaStatusBanner />
}

<div class="search-box">
    <input @bind="_query" @bind:event="oninput" placeholder="Reference (John 3:16), Strong's (G26), or a phrase..."
           @onkeydown="OnKeyDown" disabled="@_busy" />
    <button type="button" class="btn-primary" @onclick="DoSearchAsync" disabled="@(_busy || string.IsNullOrWhiteSpace(_query))">Search</button>
</div>

<label class="toolbar-check search-notes-check" title="Also search your personal notes">
    <input type="checkbox" @bind="_includeNotes" disabled="@_busy" /> Search my notes too
</label>

@if (_mode is not null)
{
    <span class="mode-indicator">Mode: @_mode</span>
}

@if (_busy)
{
    <p class="muted"><span class="loading-spinner"></span> Searching...</p>
}

@if (_message is not null)
{
    <p class="muted">@_message</p>
}

@if (_noteResults.Count > 0)
{
    <h2 class="results-heading">From your notes</h2>
    <ul class="result-list note-results">
        @foreach (var n in _noteResults)
        {
            <li>
                @if (!string.IsNullOrWhiteSpace(n.Reference))
                {
                    <a href="@NoteRefLink(n)">@n.Reference</a>
                }
                <span class="note-badge note-badge-@n.Type.ToString().ToLowerInvariant()">@n.Type</span>
                <span class="score">score @n.Score.ToString("F3")</span>
                <span class="result-text"><strong>@n.Title</strong> — @n.Body</span>
            </li>
        }
    </ul>
}

@if (_results.Count > 0)
{
    @if (_noteResults.Count > 0)
    {
        <h2 class="results-heading">From Scripture</h2>
    }
    <ul class="result-list">
        @foreach (var r in _results)
        {
            <li>
                <a href="@VerseLink(r.OsisId)">@r.Reference</a>
                @if (r.Score is not null)
                {
                    <span class="score">score @r.Score.Value.ToString("F3")</span>
                }
                <span class="result-text">@r.Text</span>
            </li>
        }
    </ul>
}

@code {
    [SupplyParameterFromQuery] public string? Q { get; set; }

    private string _query = "";
    private SearchMode? _mode;
    private IReadOnlyList<SearchResult> _results = [];
    private IReadOnlyList<NoteSearchResult> _noteResults = [];
    private string? _message;
    private bool _busy;
    private bool _includeNotes;
    private bool _showOllamaBanner;
    private bool _autoRan;

    protected override async Task OnParametersSetAsync()
    {
        if (!_autoRan && !string.IsNullOrWhiteSpace(Q))
        {
            _autoRan = true;
            _query = Q;
            await DoSearchAsync();
        }
    }

    private async Task OnKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter" && !_busy && !string.IsNullOrWhiteSpace(_query))
        {
            await DoSearchAsync();
        }
    }

    private async Task DoSearchAsync()
    {
        var query = _query.Trim();
        if (query.Length == 0) return;

        _busy = true;
        _message = null;
        _results = [];
        _noteResults = [];
        _showOllamaBanner = false;
        _mode = SearchModeDetector.Detect(query);

        try
        {
            // Optionally search personal notes (semantic) alongside scripture — not for
            // reference lookups, which navigate away.
            if (_includeNotes && _mode != SearchMode.Reference)
            {
                try { _noteResults = await NoteSvc.SearchAsync(query, 10); }
                catch { /* Ollama needed for note search; scripture results still shown. */ }
            }

            switch (_mode)
            {
                case SearchMode.Reference:
                    await HandleReferenceAsync(query);
                    break;

                case SearchMode.Strongs:
                    _results = await Repo.GetVersesByStrongsAsync(query.ToUpperInvariant());
                    if (_results.Count == 0) _message = "No verses found for that Strong's number.";
                    break;

                default: // Semantic (and Auto fallthrough)
                    try
                    {
                        var embedding = await Embedder.EmbedAsync(query);
                        _results = await SearchService.SemanticSearchAsync(embedding, 20);
                        if (_results.Count == 0) _message = "No matching verses (are embeddings imported?).";
                    }
                    catch (Exception ex)
                    {
                        _showOllamaBanner = true;
                        _message = $"Semantic search needs Ollama running. ({ex.Message})";
                    }
                    break;
            }
        }
        finally
        {
            _busy = false;
        }
    }

    private async Task HandleReferenceAsync(string query)
    {
        // Split "Book c[:v]" into a book part and a trailing chapter[:verse].
        var m = System.Text.RegularExpressions.Regex.Match(
            query, @"^(?<book>.+?)\s+(?<chapter>\d+)(?::\d+)?$");
        if (!m.Success)
        {
            _message = "Couldn't parse reference.";
            return;
        }

        var bookPart = m.Groups["book"].Value.Trim();
        var chapter = int.Parse(m.Groups["chapter"].Value);

        var books = await Repo.GetBooksAsync();
        var book = books.FirstOrDefault(b =>
            b.Name.Equals(bookPart, StringComparison.OrdinalIgnoreCase) ||
            b.Abbreviation.Equals(bookPart, StringComparison.OrdinalIgnoreCase));

        if (book is null)
        {
            _message = "Couldn't parse reference.";
            return;
        }

        Nav.NavigateTo($"/browse/{book.Abbreviation}/{chapter}");
    }

    private static string VerseLink(string osisId)
    {
        var parts = osisId.Split('.');
        if (parts.Length >= 2) return $"/browse/{parts[0]}/{parts[1]}";
        return "/search?q=" + Uri.EscapeDataString(osisId);
    }

    private static string NoteRefLink(NoteSearchResult n)
    {
        var reference = n.Reference ?? "";
        // "Book chapter[:verse]" (handles a leading ordinal like "1 John 4:8").
        var m = System.Text.RegularExpressions.Regex.Match(
            reference, @"^(?<book>.+?)\s+(?<chapter>\d+)(?::\d+)?$");
        if (m.Success)
            return $"/browse/{Uri.EscapeDataString(m.Groups["book"].Value.Trim())}/{m.Groups["chapter"].Value}";
        if (n.Type == NoteType.Book && !string.IsNullOrWhiteSpace(reference))
            return $"/browse/{Uri.EscapeDataString(reference.Trim())}/1";
        return "/search?q=" + Uri.EscapeDataString(reference);
    }
}
