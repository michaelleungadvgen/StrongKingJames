@page "/"
@page "/browse/{Book}/{Chapter:int}"
@rendermode InteractiveServer
@inject IBibleRepository Repo
@inject NavigationManager Nav

<PageTitle>Browse - StrongKingJames</PageTitle>

<h1>Browse the Bible</h1>

<OllamaStatusBanner />

<div class="controls">
    <label>
        Book
        <select value="@_selectedAbbrev" @onchange="OnBookChanged">
            @foreach (var b in _books)
            {
                <option value="@b.Abbreviation">@b.Name</option>
            }
        </select>
    </label>
    <label>
        Chapter
        <input type="number" min="1" value="@_chapter" @onchange="OnChapterChanged" style="width: 5rem;" />
    </label>
    <div style="margin-left: auto; display: flex; gap: 0.5rem;">
        <button type="button" @onclick="PrevChapter" disabled="@(_chapter <= 1)">← Prev</button>
        <button type="button" @onclick="NextChapter">Next →</button>
    </div>
</div>

@if (_bookError is not null)
{
    <p class="muted">@_bookError</p>
}
else if (_loading)
{
    <p class="muted"><span class="loading-spinner"></span> Loading chapter...</p>
}
else if (_verses.Count == 0)
{
    <p class="muted">No verses — has the Bible been imported?</p>
}
else
{
    <article class="chapter-card">
        <header class="chapter-header">
            <h2>@_selectedName @_chapter</h2>
        </header>
        <div class="chapter-text">
            @foreach (var v in _verses)
            {
                <VerseView Verse="v" OnWordClicked="ShowStrongs" />
            }
        </div>
    </article>
}

@if (_selectedStrongs is not null)
{
    <StrongsPopover Numbers="_selectedStrongs" OnClose="() => _selectedStrongs = null" />
}

@code {
    [Parameter] public string? Book { get; set; }
    [Parameter] public int Chapter { get; set; }

    private IReadOnlyList<Book> _books = [];
    private IReadOnlyList<Verse> _verses = [];
    private string _selectedAbbrev = "";
    private string _selectedName = "";
    private int _chapter = 1;
    private bool _loading;
    private IReadOnlyList<string>? _selectedStrongs;
    private string? _appliedRouteKey;
    private string? _bookError;

    protected override async Task OnInitializedAsync()
    {
        _books = await Repo.GetBooksAsync();
    }

    protected override async Task OnParametersSetAsync()
    {
        if (_books.Count == 0) return;

        if (Book is null)
        {
            // Default landing ("/"): navigate to the first book / chapter 1 so all
            // browsing flows through a single URL-driven load path.
            if (_selectedAbbrev.Length == 0)
            {
                Nav.NavigateTo($"/browse/{Uri.EscapeDataString(_books[0].Abbreviation)}/1");
            }
            return;
        }

        // Apply route parameters (from pickers, citation links, or direct URLs)
        // once per unique route. The URL is the single source of truth.
        var routeKey = $"{Book}/{Chapter}";
        if (routeKey == _appliedRouteKey) return;
        _appliedRouteKey = routeKey;

        var resolved = ResolveBook(Book);
        if (resolved is null)
        {
            _bookError = $"Unknown book '{Book}'.";
            _verses = [];
            _selectedStrongs = null;
            _selectedAbbrev = "";
            return;
        }

        _bookError = null;
        _selectedAbbrev = resolved.Abbreviation;
        _selectedName = resolved.Name;
        _chapter = Chapter > 0 ? Chapter : 1;
        await LoadChapterAsync();
    }

    private Book? ResolveBook(string value) => _books.FirstOrDefault(b =>
        b.Abbreviation.Equals(value, StringComparison.OrdinalIgnoreCase) ||
        b.Name.Equals(value, StringComparison.OrdinalIgnoreCase));

    private void OnBookChanged(ChangeEventArgs e)
    {
        var abbrev = e.Value?.ToString() ?? "";
        if (abbrev.Length == 0) return;
        NavigateTo(abbrev, 1);
    }

    private void OnChapterChanged(ChangeEventArgs e)
    {
        if (int.TryParse(e.Value?.ToString(), out var c))
        {
            NavigateTo(_selectedAbbrev, c);
        }
    }

    private void PrevChapter() => NavigateTo(_selectedAbbrev, _chapter - 1);

    private void NextChapter() => NavigateTo(_selectedAbbrev, _chapter + 1);

    private void NavigateTo(string abbrev, int chapter)
    {
        if (abbrev.Length == 0) return;
        if (chapter < 1) chapter = 1;
        Nav.NavigateTo($"/browse/{Uri.EscapeDataString(abbrev)}/{chapter}");
    }

    private async Task LoadChapterAsync()
    {
        if (_selectedAbbrev.Length == 0) return;
        _loading = true;
        _selectedStrongs = null;
        _verses = await Repo.GetChapterAsync(_selectedAbbrev, _chapter);
        _loading = false;
    }

    private void ShowStrongs(List<string> numbers) => _selectedStrongs = numbers;
}
